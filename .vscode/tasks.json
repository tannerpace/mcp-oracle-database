{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start MCP Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "start"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Query Database (Test Client)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test-client"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Build TypeScript",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Manual Test: Core MCP Tools",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test-client"],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Manual Test: Discovery MCP Tools",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test-discovery"],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Manual Test: Full MCP Tool Suite",
      "type": "shell",
      "command": "npm run build && npm run test-client && npm run test-discovery",
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Manual Test: Run SQL Query (Prompt)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test-query"],
      "options": {
        "env": {
          "SQL_QUERY": "${input:mcpSqlQuery}"
        }
      },
      "dependsOn": "Build TypeScript",
      "problemMatcher": [],
      "group": "test"
    }
  ],
  "inputs": [
    {
      "id": "mcpSqlQuery",
      "type": "promptString",
      "description": "SQL query for query_database tool (SELECT only)",
      "default": "SELECT USER AS current_user, SYSDATE AS current_date FROM DUAL"
    }
  ]
}
